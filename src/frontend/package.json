{
  "name": "dictaphone",
  "private": true,
  "version": "0.10.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build-theme": "cunningham -g css,scss,ts -o src/styles && mv src/styles/cunningham-tokens.scss src/styles/cunningham-tokens-sass.scss",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "format": "prettier --write ./src",
    "check": "prettier --check ./src"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@formatjs/intl-durationformat": "0.10.14",
    "@gouvfr-lasuite/cunningham-react": "4.3.0",
    "@gouvfr-lasuite/ui-kit": "0.23.2",
    "@react-aria/toast": "3.1.1",
    "@react-types/overlays": "3.10.0",
    "@tanstack/react-query": "5.101.0",
    "clsx": "2.1.1",
    "date-fns": "4.4.0",
    "hoofd": "1.7.3",
    "humanize-duration": "3.33.2",
    "i18next": "26.3.1",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "idb": "8.0.3",
    "marked": "18.0.5",
    "posthog-js": "1.386.4",
    "pretty-bytes": "7.1.0",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-aria-components": "1.18.0",
    "react-dom": "19.2.7",
    "react-dropzone": "15.0.0",
    "react-i18next": "17.0.8",
    "react-toastify": "11.0.5",
    "uuid": "14.0.0",
    "wouter": "3.10.0",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "0.2.3",
    "@tanstack/eslint-plugin-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@types/humanize-duration": "3.27.4",
    "@types/node": "^24.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "postcss": "8.5.15",
    "prettier": "3.8.4",
    "sass-embedded": "1.100.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0",
    "vite": "8.0.16",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.8"
  }
}
